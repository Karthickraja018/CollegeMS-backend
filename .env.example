# ── Application ─────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-secret-key-in-production

# ── Database ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/collegems

# ── JWT ──────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Provider ───────────────────────────────────────────────────────────────────
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# Stub keys (leave blank unless you have them)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Reports ───────────────────────────────────────────────────────────────────────
REPORTS_DIR=./reports
